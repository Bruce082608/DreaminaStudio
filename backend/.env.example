ENV=production

# Required in production. Generate with: openssl rand -hex 32
DREAMINA_AUTH_SECRET=change-this-to-a-long-random-secret

# Default admin bootstrap. Existing database users are not overwritten.
DREAMINA_ADMIN_EMAIL=admin@dreamina.local
DREAMINA_ADMIN_PASSWORD=Dreamina@2026

# Backend persistent directories on the server host.
DREAMINA_DATA_DIR=/var/lib/dreamina_studio/backend-data
DREAMINA_CLI_HOME_DIR=/var/lib/dreamina_studio/cli-home
DREAMINA_DATABASE_URL=sqlite:////app/data/dreamina_studio.sqlite3

# Storyboard service.
DEEPSEEK_API_KEY=

# Verification codes. Keep false on public production once SMTP is configured.
DREAMINA_VERIFICATION_DEV_MODE=false
DREAMINA_VERIFICATION_CODE_TTL_SECONDS=600
DREAMINA_VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# Email verification via QQ Mail SMTP. Use the QQ Mail SMTP authorization code as password.
DREAMINA_SMTP_HOST=smtp.qq.com
DREAMINA_SMTP_PORT=465
DREAMINA_SMTP_USERNAME=873831183@qq.com
DREAMINA_SMTP_PASSWORD=
DREAMINA_SMTP_FROM=873831183@qq.com
DREAMINA_SMTP_TLS=false
DREAMINA_SMTP_SSL=true
